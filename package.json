{
  "name": "invoice",
  "private": true,
  "version": "2.0.3",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "ELECTRON=true vite",
    "electron:build-main": "npx esbuild electron/main.ts electron/preload.ts --bundle --platform=node --format=cjs --target=node20 --external:electron --outdir=dist-electron --out-extension:.js=.cjs",
    "electron:build": "npm run build && npm run electron:build-main && electron-builder",
    "electron:preview": "npm run build && npm run electron:build-main && unset ELECTRON_RUN_AS_NODE && electron .",
    "test.e2e": "cypress run",
    "test.unit": "vitest",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "lint": "eslint",
    "ionic:build": "npm run build",
    "ionic:serve": "npm run dev"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1033.0",
    "@aws-sdk/client-s3": "^3.1033.0",
    "@aws-sdk/s3-request-presigner": "^3.1033.0",
    "@aws-sdk/util-dynamodb": "^3.996.2",
    "@bcyesil/capacitor-plugin-printer": "^0.0.5",
    "@capacitor-community/admob": "^8.0.0",
    "@capacitor/android": "^8.0.2",
    "@capacitor/app": "^8.0.0",
    "@capacitor/core": "^8.0.2",
    "@capacitor/device": "^8.0.0",
    "@capacitor/filesystem": "^8.1.0",
    "@capacitor/ios": "^8.0.2",
    "@capacitor/keyboard": "^8.0.0",
    "@capacitor/preferences": "^8.0.0",
    "@capacitor/share": "^8.0.0",
    "@capacitor/status-bar": "^8.0.0",
    "@ionic/react": "^8.7.17",
    "@ionic/react-router": "^8.7.17",
    "@types/crypto-js": "^4.2.2",
    "@types/react-router-dom": "^5.3.3",
    "aws-amplify": "^6.16.4",
    "axios": "^1.13.4",
    "capacitor-email-composer": "^6.0.0",
    "chart.js": "^4.5.1",
    "crypto-js": "^4.2.0",
    "framer-motion": "^12.29.2",
    "html2canvas": "^1.4.1",
    "ionicons": "^8.0.13",
    "jspdf": "^4.0.0",
    "react": "^19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.0",
    "react-router": "^5.3.4",
    "react-router-dom": "^5.3.4",
    "react-signature-canvas": "^1.1.0-alpha.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.2",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-signature-canvas": "^1.0.7",
    "@vitejs/plugin-legacy": "^5.4.3",
    "@vitejs/plugin-react": "^5.1.2",
    "cypress": "^13.5.0",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.2",
    "jsdom": "^22.1.0",
    "terser": "^5.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "description": "An Ionic project"
}
